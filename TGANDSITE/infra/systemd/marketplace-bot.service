[Unit]
Description=Market Hub Telegram bot
After=network.target marketplace-api.service
Requires=marketplace-api.service

[Service]
Type=simple
WorkingDirectory=/opt/tg-site-marketplace
EnvironmentFile=/opt/tg-site-marketplace/.env
ExecStart=/usr/bin/node src/bot.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
